# MagguuUI - example environment
# Copy this file to .env and replace placeholder values.

NODE_ENV=production

# Required in production
NUXT_JWT_SECRET=change-me-generate-a-random-64-char-string

# Required only for fresh production setups without an existing admin user
NUXT_ADMIN_PASSWORD=change-me-set-a-strong-password

# Optional
NUXT_AUTH_COOKIE_NAME=magguuui_session

# Optional: API key for GitHub Actions / sync scripts
NUXT_API_KEY=change-me-generate-another-random-string

# Optional: GitHub integration
NUXT_GITHUB_TOKEN=
NUXT_GITHUB_REPO=Derpsen/MagguuUI
NUXT_GITHUB_WEBHOOK_SECRET=

# Optional: force-sync seeded guide/FAQ content from code into the DB on startup
NUXT_SYNC_SEEDED_CONTENT=false

# Optional: WebAuthn / Passkeys
NUXT_WEBAUTHN_RP_ID=
NUXT_WEBAUTHN_ORIGIN=

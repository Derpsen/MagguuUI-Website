{
  "name": "magguuui",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "MagguuUI — World of Warcraft UI Configuration Manager",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "build:clean": "node scripts/clean-build-artifacts.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit --pretty false",
    "preview": "nuxt preview",
    "verify:smoke": "node scripts/verify-build.mjs",
    "verify": "npm run build:clean && npm run postinstall && npm run build && npm run verify:smoke",
    "audit:prod": "npm audit --omit=dev",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/database/seed.ts",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:install": "playwright install chromium"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@iconify-json/heroicons": "^1.2.0",
    "@iconify-json/simple-icons": "^1.2.0",
    "@nuxt/ui": "^4.9.0",
    "@resvg/resvg-js": "^2.6.2",
    "@simplewebauthn/browser": "^13.2.0",
    "@simplewebauthn/server": "^13.2.0",
    "@tiptap/extension-link": "^3.24.0",
    "@tiptap/extension-placeholder": "^3.24.0",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-underline": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "@tiptap/vue-3": "^3.24.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.0",
    "drizzle-orm": "^0.45.0",
    "echarts": "^6.1.0",
    "h3": "^1.13.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.5",
    "nitropack": "^2.13.4",
    "nuxt": "^4.4.8",
    "nuxt-og-image": "^6.5.2",
    "sanitize-html": "^2.17.2",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.0",
    "vue-echarts": "^8.0.1",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@playwright/test": "^1.52.0",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/sanitize-html": "^2.16.1",
    "drizzle-kit": "^0.31.0",
    "eslint": "^10.6.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}

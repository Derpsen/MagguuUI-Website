# ─── MagguuUI v2 — Environment Variables ─────────
# Copy this file to .env and fill in your values

# Node environment
NODE_ENV=production

# Admin password (will be hashed on first setup)
NUXT_ADMIN_PASSWORD=changeme

# JWT Secret (generate with: openssl rand -hex 32)
NUXT_JWT_SECRET=change-me-generate-a-random-64-char-string

# Optional: custom auth cookie name for HttpOnly admin sessions
NUXT_AUTH_COOKIE_NAME=magguuui_session

# API Key for GitHub Actions / sync scripts
NUXT_API_KEY=change-me-generate-another-random-string

# GitHub integration (for auto-sync on string changes)
NUXT_GITHUB_TOKEN=ghp_your_github_personal_access_token
NUXT_GITHUB_REPO=Derpsen/MagguuUI

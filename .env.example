NUXT_JWT_SECRET=
NUXT_ADMIN_PASSWORD=

# Optional auth/session settings
NUXT_AUTH_COOKIE_NAME=
NUXT_FORCE_PASSWORD_RESET=

# Canonical AddOn sync API (required when workflow sync is enabled)
API_BEARER_TOKEN=

# Optional GitHub sync/webhook integration
NUXT_GITHUB_TOKEN=
NUXT_GITHUB_REPO=Derpsen/MagguuUI
NUXT_GITHUB_WEBHOOK_SECRET=

# Optional WebAuthn/passkeys
NUXT_WEBAUTHN_RP_ID=
NUXT_WEBAUTHN_ORIGIN=

# Optional content seed behavior
NUXT_SYNC_SEEDED_CONTENT=

# OG image request signing for dynamic nuxt-og-image URLs
# Generate outside the repo with: npx nuxt-og-image generate-secret
NUXT_OG_IMAGE_SECRET=
